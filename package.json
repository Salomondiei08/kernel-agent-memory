{
  "name": "kernel-agent-memory",
  "version": "0.0.3",
  "description": "Shared memory across Claude Code, Codex, and OpenCode sessions",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "kernel": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs/assets",
    "README.md",
    "VERSION.md",
    "LICENSE"
  ],
  "keywords": [
    "agent",
    "memory",
    "claude-code",
    "codex",
    "opencode",
